# Cấu hình môi trường cho ProxyManager Server
# Tự động cấu hình theo IP của node này: 10.0.3.98

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=proxymanager

# gRPC Server (Để Client kết nối về)
SERVER_IP=10.0.3.98
GRPC_PORT=50051

# FRP Server (FRPS)
FRPS_BIND_PORT=7000
FRPS_VHOST_HTTP_PORT=8080
FRPS_VHOST_HTTPS_PORT=8443
FRPS_DASHBOARD_PORT=7500
FRPS_TOKEN=SECRET_TOKEN_MANAGED_BY_DASHBOARD
