# FrpManager Configuration Template

# Database Configuration
DB_USER=root
DB_PASSWORD=your_secure_password
DB_NAME=proxymanager
DB_HOST=127.0.0.1
DB_PORT=3306

# API & Security
JWT_SECRET=generate_a_random_secret_here
AGENT_AUTH_TOKEN=generate_a_random_token_for_agents

# FRP Configuration
FRP_SERVER_ADDR=your_server_public_ip
FRP_SERVER_PORT=7000
FRP_TOKEN=your_frp_token

# Wildcard Domain Configuration
VITE_WILDCARD_DOMAIN=yourdomain.com
